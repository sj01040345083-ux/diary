# ─────────────────────────────────────────────
# 환경 변수 예시 파일 (.env.example)
#
# 사용 방법:
#   1. 이 파일을 복사해서 이름을 ".env" 로 바꾸세요.
#   2. 아래 빈 값에 Supabase 프로젝트의 실제 값을 붙여넣으세요.
#
# ⚠️ ".env" 파일은 GitHub에 올라가지 않습니다 (.gitignore 에 등록됨).
#    실제 비밀 키는 절대 공개 저장소에 올리지 마세요.
#    (secret / service_role 키는 프론트엔드/공개 저장소에 절대 넣지 마세요.)
# ─────────────────────────────────────────────

# Supabase 프로젝트 URL (예: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase Publishable(공개용) 키 — 프론트엔드에서 사용 가능한 공개 키입니다
VITE_SUPABASE_PUBLISHABLE_KEY=
